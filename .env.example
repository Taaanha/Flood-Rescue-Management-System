APP_ENV=local

# Local PostgreSQL (used when APP_ENV=local)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_PASSWORD
POSTGRES_DB=flood_management_system
POSTGRES_SSLMODE=disable

# Cloud PostgreSQL (used when APP_ENV=production or APP_ENV=cloud)
# Example (Neon):
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&channel_binding=require
DATABASE_URL=
